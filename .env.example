PET_BRIDGE_HOST=127.0.0.1
PET_BRIDGE_PORT=17366
PET_BRIDGE_LOG=./events.jsonl
PET_BRIDGE_STATE=./bridge-state.json

# Set this if the bridge is reachable over LAN or through an untrusted local path.
# Clients may send it as Authorization: Bearer <token>, x-pet-bridge-token, or ?token=<token>.
PET_BRIDGE_TOKEN=

# Keep raw upstream payloads out of logs by default.
PET_BRIDGE_STORE_RAW=0
PET_BRIDGE_MAX_BODY_BYTES=65536
PET_BRIDGE_MAX_MESSAGE_CHARS=500
PET_BRIDGE_SINK_TIMEOUT_MS=1200
PET_BRIDGE_OUTBOX_MAX=300
PET_BRIDGE_OUTBOX_FLUSH_MAX=25

# Reminder behavior.
PET_NOTIFY_STATUSES=needs-attention,completed,near-complete,error
PET_NOTIFY_THROTTLE_MS=15000

# Optional outbound sinks.
PET_WEBHOOK_URL=
PET_NOTIFICATION_WEBHOOK_URL=
PET_WEBHOOK_TOKEN=

# Optional XiaoZhi assistant hub sink.
# Sends normalized events to <url>/assistant/notifications and lets the Mac mini
# backend decide screen colors, green completion flash, brightness, and ack state.
XIAOZHI_ASSISTANT_URL=
XIAOZHI_SOURCE_PREFIX=
XIAOZHI_WEBHOOK_TOKEN=

# Optional local client spooler used by hooks and lightweight sync daemons.
PET_NOTIFY_QUEUE=~/.codex-pet-bridge/notify-outbox.jsonl
PET_NOTIFY_TIMEOUT_MS=1200
PET_AGENT_SYNC_PREFIX=local
PET_AGENT_SYNC_INTERVAL_MS=15000
